<%- include('../partials/header') %>

<div class="container mt-5" id="imz2fx">
    <div class="row">
        <div class="col-md-6">
            <img src="/images/<%= package.image %>" class="img-fluid rounded shadow">
        </div>

        <div class="col-md-6">
            <h2><%= package.title %></h2>
            <p class="text-muted"><%= package.destination %></p>

            <h4 class="text-success">₹<%= package.price %></h4>

            <p><%= package.description %></p>

            <a href="/api/booking?package=<%= package._id %>" class="btn btn-success">
                Book Now
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>