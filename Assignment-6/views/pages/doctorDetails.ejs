<%- include('../partials/header') %>

<h2><%= doctor.name %></h2>
<p>Specialization: <%= doctor.specialization %></p>
<p>Experience: <%= doctor.experience %> years</p>
<p>Fee: ₹<%= doctor.fee %></p>
<h3>Appointments for this Doctor</h3>

<% if (appointments.length > 0) { %>
  <% appointments.forEach(app => { %>
    <div>
      <p><strong>Patient:</strong> <%= app.user.name %></p>
      <p><strong>Time:</strong> <%= app.slot %></p>
      <p><strong>Date:</strong> <%= app.date.toDateString() %></p>
      <hr>
    </div>
  <% }) %>
<% } else { %>
  <p>No appointments yet.</p>
<% } %>

<% if (typeof user !== 'undefined' && user) { %>

  <!-- SHOW FORM ONLY IF LOGGED IN -->
  <form action="/book" method="POST">
    
    <input type="hidden" name="doctorId" value="<%= doctor._id %>" />

    <input type="text" name="patientName" placeholder="Your Name" required />

    <input type="date" name="date" required />

    <select name="slot">
      <% doctor.availableSlots.forEach(slot => { %>
        <option><%= slot %></option>
      <% }) %>
    </select>

    <button type="submit">Book Appointment</button>
  </form>

<% } else { %>

  <!-- IF NOT LOGGED IN -->
  <p style="color:red;">
    Please <a href="/login">login</a> to book an appointment.
  </p>

<% } %>

<%- include('../partials/footer') %>