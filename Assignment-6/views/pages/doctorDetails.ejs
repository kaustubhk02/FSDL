<%- include('../partials/header') %>

<div class="container my-4">
  <div class="card p-4 mb-4 shadow-sm">
    <h2 class="mb-1"><%= doctor.name %></h2>
    <p class="text-muted mb-1"><strong>Specialization:</strong> <%= doctor.specialization %></p>
    <p class="mb-1"><strong>Experience:</strong> <%= doctor.experience %> years</p>
    <p class="mb-0"><strong>Consultation Fee:</strong> ₹<%= doctor.fee %></p>
  </div>

  <!-- ── Booking Form (only for logged-in patients) ── -->
  <% if (typeof user !== 'undefined' && user) { %>
    <div class="card p-4 mb-4 shadow-sm">
      <h4 class="mb-3">Book an Appointment</h4>
      <form action="/book" method="POST">
        <input type="hidden" name="doctorId" value="<%= doctor._id %>" />

        <div class="mb-3">
          <label class="form-label">Date</label>
          <input type="date" name="date" class="form-control" required
                 min="<%= new Date().toISOString().split('T')[0] %>" />
        </div>

        <div class="mb-3">
          <label class="form-label">Select Slot</label>
          <select name="slot" class="form-select" required>
            <option value="" disabled selected>-- Choose a time slot --</option>
            <% doctor.availableSlots.forEach(slot => { %>
              <option value="<%= slot %>"><%= slot %></option>
            <% }) %>
          </select>
        </div>

        <button type="submit" class="btn btn-primary">Book Appointment</button>
      </form>
    </div>
  <% } else { %>
    <div class="alert alert-warning">
      Please <a href="/login">login</a> to book an appointment.
    </div>
  <% } %>

  <!-- ── Appointment history for this doctor ── -->
  <h4 class="mb-3">Existing Appointments</h4>
  <% if (appointments.length > 0) { %>
    <% appointments.forEach(app => { %>
      <div class="card p-3 mb-2 shadow-sm">
        <%
          // ✅ app.user is now properly populated from the DB
          const patientDisplay = app.user ? app.user.name : app.patientName;
        %>
        <p class="mb-1"><strong>Patient:</strong> <%= patientDisplay %></p>
        <p class="mb-1"><strong>Slot:</strong> <%= app.slot %></p>
        <p class="mb-0"><strong>Date:</strong> <%= app.date.toDateString() %></p>
      </div>
    <% }) %>
  <% } else { %>
    <p class="text-muted">No appointments yet for this doctor.</p>
  <% } %>
</div>

<%- include('../partials/footer') %>
