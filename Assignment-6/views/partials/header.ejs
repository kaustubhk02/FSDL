<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Doctor Appointment System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<nav class="navbar navbar-dark px-3" style="background:#2c3e50;">
  <a class="navbar-brand fw-bold" href="/">DoctorsDoor</a>
  <div class="d-flex gap-3 align-items-center">
    <a class="text-white text-decoration-none" href="/doctors">Doctors</a>

    <% if (user) { %>
      <a class="text-white text-decoration-none" href="/appointments">My Appointments</a>
      <!-- Shows user.name (full name), not username -->
      <span class="text-white"><%= user.name %></span>
      <a class="btn btn-outline-light btn-sm" href="/logout">Logout</a>
    <% } else { %>
      <a class="btn btn-outline-light btn-sm" href="/login">Login</a>
      <a class="btn btn-success btn-sm" href="/signup">Sign Up</a>
    <% } %>
  </div>
</nav>

<div class="container mt-3">
